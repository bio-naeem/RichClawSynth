# Copy this file to .env and fill in the values before running the pipeline.

OPENAI_MODEL=glm-5.1
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/
OPENAI_API_KEY=
OPENAI_TIMEOUT=120

# Step1 bundle judge policy
STEP1_JUDGE_MAX_RESAMPLES=3
STEP1_JUDGE_PASS_THRESHOLD=19
STEP1_JUDGE_SINGLE_GOAL_FLOOR=4
STEP1_JUDGE_ROLE_CHAIN_FLOOR=4
STEP1_JUDGE_NATURALNESS_FLOOR=4

# Optional local overrides
SKILLS_POOL=
PERSONAS_PATH=

# Step5 file generation (optional)
WORKSPACE_HUB=
WORKSPACE_BASE=
RESULTS_DIR=
SKILLS_SOURCE=
